{"event_id":"evt_assumptiondeclared_asm_no_hepatic_exposure_response_mqyzlpgw_a4a492ad","event_type":"AssumptionDeclared","thread_id":"thd_arm_pkpd_modeling_ltn4481_r2","actor_id":"par_clin_pharm","timestamp":"2026-06-29T09:00:00.176Z","payload":{"assumption":{"id":"asm_no_hepatic_exposure_response","object":"assumption","threadId":"thd_arm_pkpd_modeling_ltn4481_r2","text":"No dose-safety exposure-response was established for the hepatic signal; the 200mg selection is efficacy-driven, and dose is not being used as a lever to manage hepatotoxicity.","status":"active","evidenceIds":["evd_hepatic_exposure_response"],"confidence":0.6,"declaredByParticipantId":"par_clin_pharm","declaredAt":"2026-06-29T09:00:00.176Z","contentHash":"sha256:arm_asm_no_hepatic_exposure_response"}},"protocol_version":"clista.protocol.v0","hash_version":"clista.event_hash.v1","previous_hash":"sha256:96cfe0829db3b1a71895a521b5b5f01d0ecafa49f0b23dc0c01e90e2c6f97c6e","content_hash":"sha256:66ca5104330c5b48618f41ce562b8c8c0638292891a92901ebbb817d3e4b3575"}
