{"event_id":"evt_assumptiondeclared_asm_subgroup_exploratory_only_mqyzlpws_a43c19d0","event_type":"AssumptionDeclared","thread_id":"thd_arm_subgroup_review_ltn4481","actor_id":"par_biostat","timestamp":"2026-06-29T09:00:01.034Z","payload":{"assumption":{"id":"asm_subgroup_exploratory_only","object":"assumption","threadId":"thd_arm_subgroup_review_ltn4481","text":"The bio-failure subgroup finding is hypothesis-generating only and should not drive Phase III enrichment, stratification, or primary endpoint strategy.","status":"active","evidenceIds":["evd_subgroup_data","evd_fda_subgroup_guidance"],"confidence":0.72,"declaredByParticipantId":"par_biostat","declaredAt":"2026-06-29T09:00:01.034Z","contentHash":"sha256:arm_asm_subgroup_exploratory_only"}},"protocol_version":"clista.protocol.v0","hash_version":"clista.event_hash.v1","previous_hash":"sha256:0516e5930a976c592ba169aff8464431051cbfd25882b1dae4977c3256a8ced8","content_hash":"sha256:e77b86c1619f1c87caf4c4ce0a40bfb24a13dfa01f73e895078c4ac0b5672d03"}
